<view wx:if="{{visible}}" class="overlay">
    <view class="dialog">
        <view class="dialog__title dialog__title--{{scanStatus}}">
            <text wx:if="{{scanStatus === 'waiting'}}">等待贴近标签</text>
            <text wx:elif="{{scanStatus === 'writing'}}">写入中</text>
            <text wx:elif="{{scanStatus === 'success'}}">写入成功</text>
            <text wx:elif="{{scanStatus === 'error'}}">操作失败</text>
        </view>

        <view class="dialog__body">
            <view class="stage stage--{{scanStatus}}">
                <view class="detect-scene" wx:if="{{scanStatus === 'waiting'}}">
                    <view class="nphone nphone--detect">
                        <pixel-icon name="phone" size="64" />
                    </view>
                    <view class="ntag ntag--detect">
                        <pixel-icon name="nfc" size="32" />
                        <text>NFC</text>
                    </view>
                </view>
                <view class="hint hint--center" wx:if="{{scanStatus === 'waiting'}}">请将 NFC 标签贴近手机感应区</view>

                <view class="spin" wx:if="{{scanStatus === 'writing'}}"></view>
                <view class="hint hint--center hint--green" wx:if="{{scanStatus === 'writing'}}">正在写入，请勿移动标签</view>

                <pixel-icon name="check" size="64" wx:if="{{scanStatus === 'success'}}" />
                <view class="hint hint--center hint--green" wx:if="{{scanStatus === 'success'}}">{{successMessage}}</view>
                <view class="hint hint--center hint--green" wx:if="{{scanStatus === 'success'}}">{{successSubMessage}}</view>

                <pixel-icon name="error" size="64" wx:if="{{scanStatus === 'error'}}" />
                <view class="hint hint--center hint--red" wx:if="{{scanStatus === 'error' && errorMessage}}">{{errorMessage}}</view>
                <view class="hint hint--center hint--red" wx:if="{{scanStatus === 'error' && !errorMessage}}">标签可能已损坏或容量不足，请更换标签后重试</view>
            </view>
        </view>

        <view class="dialog__actions dialog__actions--one" wx:if="{{scanStatus === 'waiting' || scanStatus === 'writing'}}">
            <button class="dialog-btn" bindtap="handleCancel">取消</button>
        </view>

        <view
            class="dialog__actions {{successSecondaryText ? 'dialog__actions--two' : 'dialog__actions--one'}}"
            wx:if="{{scanStatus === 'success'}}"
        >
            <button class="dialog-btn" bindtap="handlePrimaryAction">{{successPrimaryText}}</button>
            <button
                wx:if="{{successSecondaryText}}"
                class="dialog-btn dialog-btn--green"
                bindtap="handleSecondaryAction"
            >
                {{successSecondaryText}}
            </button>
        </view>

        <view class="dialog__actions dialog__actions--two" wx:if="{{scanStatus === 'error'}}">
            <button class="dialog-btn dialog-btn--red" bindtap="handleRetry">重试</button>
            <button class="dialog-btn dialog-btn--green" bindtap="handlePrimaryAction">确定</button>
        </view>
    </view>
</view>
