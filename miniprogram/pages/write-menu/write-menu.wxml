<pixel-navbar title="NFC" theme="home" showBack="{{false}}" showHome="{{false}}" />
<pixel-toast id="pixel-toast" />

<view class="write-menu" style="min-height: calc(100vh - {{navHeight}}px);">
    <view class="write-menu__content">
        <view class="stack">
            <view class="card card--orange card--pixel-cut home-main" bindtap="handleWriteApp">
                <view class="card__bite card__bite--tl"></view>
                <view class="card__bite card__bite--br"></view>
                <view class="home-deco home-deco--a"></view>
                <view class="home-deco home-deco--b"></view>
                <view class="home-deco home-deco--c"></view>
                <view class="row">
                    <view class="home-main__visual">
                        <view class="home-main__sun"></view>
                        <view class="home-main__spark home-main__spark--a"></view>
                        <view class="home-main__spark home-main__spark--b"></view>
                        <view class="home-main__platform"></view>
                        <view class="home-main__sprite-wrap">
                            <pixel-icon name="app" size="56" />
                        </view>
                    </view>
                    <view class="home-main__content">
                        <view class="card__title">应用专区</view>
                        <view class="meta">常用应用一碰直达，适合桌面标签、车载支架和办公入口。</view>
                    </view>
                </view>
            </view>

            <view class="home-subgrid">
                <view class="card card--purple card--pixel-cut home-sub" bindtap="handleWriteMusic">
                    <view class="card__bite card__bite--tl"></view>
                    <view class="row">
                        <view class="home-sub__visual">
                            <pixel-icon name="music" size="48" />
                        </view>
                        <view class="body">
                            <view class="card__title">音乐专区</view>
                            <view class="meta">支持网易云和 QQ 音乐分享链接写入。</view>
                        </view>
                    </view>
                </view>

                <view class="card card--cyan card--pixel-cut home-sub" bindtap="handleWriteWeb">
                    <view class="card__bite card__bite--br"></view>
                    <view class="row">
                        <view class="home-sub__visual">
                            <pixel-icon name="web" size="48" />
                        </view>
                        <view class="body">
                            <view class="card__title">网页专区</view>
                            <view class="meta">官网、活动页和短链都可以直接写入。</view>
                        </view>
                    </view>
                </view>

                <view class="card card--green card--pixel-cut home-sub home-sub--wide" bindtap="handleWriteLocalAudio">
                    <view class="card__bite card__bite--tl"></view>
                    <view class="card__bite card__bite--br"></view>
                    <view class="row">
                        <view class="home-sub__visual home-sub__visual--audio">
                            <pixel-icon name="record" size="48" />
                        </view>
                        <view class="body">
                            <view class="card__title">本地音频</view>
                            <view class="meta">从微信会话选择音频文件，上传云存储后生成播放链接并写入 NFC。</view>
                        </view>
                    </view>
                </view>
            </view>
        </view>
    </view>
</view>

<button class="fab" open-type="contact">
    <pixel-icon name="question" size="44" />
</button>

<view wx:if="{{developerPromiseDialogVisible}}" class="overlay">
    <view class="dialog">
        <view class="dialog__title">开发者承诺</view>
        <view class="dialog__body">
            <view class="promise">
                <view>1. 小程序仅在本地和云开发环境中处理本次写卡所需数据。</view>
                <view>2. 本地音频文件会上传到你的云存储，并通过云函数记录数据库信息。</view>
                <view>3. 写入前请再次确认内容，删除文件后旧 NFC 链接会失效。</view>
            </view>
        </view>
        <view class="dialog__actions dialog__actions--one">
            <button class="dialog-btn dialog-btn--green" bindtap="handleCloseDeveloperPromiseDialog">我知道了</button>
        </view>
    </view>
</view>

<view wx:if="{{nfcUnsupportedDialogVisible}}" class="overlay">
    <view class="dialog">
        <view class="dialog__title dialog__title--red">NFC 不可用</view>
        <view class="dialog__body">
            <view class="stage">
                <pixel-icon name="phone" size="64" />
                <view class="hint hint--center hint--red">当前设备暂不支持 NFC 写入。</view>
                <view class="hint hint--center hint--red">你仍然可以查看页面和管理云端文件。</view>
            </view>
        </view>
        <view class="dialog__actions dialog__actions--one">
            <button class="dialog-btn dialog-btn--red" bindtap="handleCloseUnsupportedDialog">我知道了</button>
        </view>
    </view>
</view>
