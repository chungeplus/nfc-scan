<pixel-navbar title="写入网页" theme="web" showBack="{{true}}" showHome="{{false}}" />
<pixel-toast id="pixel-toast" />

<view class="write-web" style="height: calc(100vh - {{navHeight}}px);">
    <view class="field">
        <view class="label">网址链接</view>
        <textarea
            class="box box--tall box--textarea"
            value="{{webUrl}}"
            placeholder="https://github.com"
            maxlength="-1"
            bindinput="handleWebUrlInput"
        ></textarea>
        <view class="field__error" wx:if="{{urlError}}">{{urlError}}</view>
    </view>
    
    <view class="btn-wrap">
        <button class="btn" bindtap="handlePasteTap">粘贴</button>
    </view>
    
    <button class="primary-btn" disabled="{{!canSubmit}}" bindtap="handleOpenScanDialog">写入 NFC 标签</button>
</view>

<button class="fab" open-type="contact">
    <pixel-icon name="question" size="44" />
</button>

<scan-dialog visible="{{scanVisible}}" records="{{records}}" bind:close="handleCloseScanDialog" />
