<pixel-navbar title="音乐写入" theme="music" showBack="{{true}}" showHome="{{false}}" />
<pixel-toast id="pixel-toast" />
<scan-dialog visible="{{scanVisible}}" records="{{records}}" bind:close="handleCloseScanDialog" />

<view class="page" style="padding-top: {{navHeight}}px;">
    <view class="page__content">
        <view class="section">
            <view class="section__title">支持的平台</view>
            <view class="platform-tags">
                <view class="tag tag--green">网易云音乐</view>
                <view class="tag tag--green">QQ音乐</view>
            </view>
        </view>

        <view class="section">
            <view class="section__title">粘贴分享链接</view>
            <view class="textarea-group">
                <textarea class="textarea" value="{{shareUrl}}" placeholder="粘贴网易云音乐或QQ音乐分享链接" bindinput="handleShareUrlInput" maxlength="500" />
                <view class="textarea-action" bindtap="handlePasteTap">
                    <pixel-icon name="record" size="20" />
                    <text>粘贴</text>
                </view>
            </view>
        </view>

        <view class="tips">
            <pixel-icon name="question" size="16" />
            <text>分享链接获取方式：打开音乐APP → 点击分享 → 复制链接</text>
        </view>

        <button class="btn btn--primary" bindtap="handleOpenScanDialog" disabled="{{!canSubmit || parsingLoading}}">
            {{parsingLoading ? '解析中...' : '开始写入 NFC'}}
        </button>
    </view>
</view>
