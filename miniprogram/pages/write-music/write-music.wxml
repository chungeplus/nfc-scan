<pixel-navbar title="写入音乐" theme="music" showBack="{{true}}" showHome="{{false}}" />
<pixel-toast id="pixel-toast" />

<view class="write-music" style="height: calc(100vh - {{navHeight}}px);">
    <view class="field">
        <view class="label">分享链接</view>
        <textarea
            class="box box--tall box--textarea"
            value="{{shareUrl}}"
            placeholder="https://y.music.163.com/m/song/186145"
            maxlength="-1"
            bindinput="handleShareUrlInput"
        ></textarea>
    </view>
    
    <view class="btn-wrap">
        <button class="btn" bindtap="handlePasteTap">粘贴</button>
    </view>
    
    <button class="primary-btn" disabled="{{!canSubmit || writeStatus !== 'input'}}" bindtap="handleOpenScanDialog">
        <text wx:if="{{writeStatus === 'input'}}">写入 NFC 标签</text>
        <text wx:elif="{{writeStatus === 'parsing'}}">解析中...</text>
    </button>
</view>

<button class="fab" open-type="contact">
    <pixel-icon name="question" size="44" />
</button>

<scan-dialog visible="{{scanVisible}}" records="{{records}}" bind:close="handleCloseScanDialog" />
