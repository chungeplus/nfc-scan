<pixel-navbar title="写入本地音视频" theme="audio" showBack="{{true}}" showHome="{{false}}" />
<pixel-toast id="pixel-toast" />

<view class="write-media" style="min-height: calc(100vh - {{navHeight}}px);">
    <view class="field">
        <button class="picker-btn" bindtap="handleChooseFile" disabled="{{submitting}}">从微信会话选择文件</button>

        <view wx:if="{{submitting}}" class="loading-card">
            <view class="loading-card__spinner"></view>
            <view class="loading-card__content">
                <view class="loading-card__title">{{submittingText}}</view>
                <view class="loading-card__desc">请稍候</view>
            </view>
        </view>

        <view wx:if="{{selectedFileName}}" class="upload-card">
            <view class="upload-card__name">{{selectedFileName}}</view>
            <view class="pill-row">
                <view class="pill">{{selectedFileSizeText}}</view>
                <view class="pill">{{selectedFileTagText}}</view>
            </view>
            <view wx:if="{{currentShareUrl}}" class="upload-link">{{currentShareUrl}}</view>
        </view>
    </view>

    <view class="field">
        <view class="label">播放页风格</view>
        <view class="theme-grid">
            <button
                wx:for="{{themeOptions}}"
                wx:key="key"
                class="theme-btn {{themeKey === item.key ? 'theme-btn--active' : ''}}"
                data-key="{{item.key}}"
                bindtap="handleSelectTheme"
            >
                {{item.label}}
            </button>
        </view>
    </view>

    <view class="field">
        <view class="label">播放页链接</view>
        <view class="box box--tall">{{currentShareUrl || linkPreviewText}}</view>
    </view>

    <button
        class="primary-btn"
        disabled="{{submitting || (!selectedFileName && !currentRecord)}}"
        bindtap="handleWriteMedia"
    >
        <text wx:if="{{submitting}}">{{submittingText}}</text>
        <text wx:else>{{primaryButtonText}}</text>
    </button>
</view>

<button class="fab" open-type="contact">
    <pixel-icon name="question" size="44" />
</button>

<scan-dialog
    visible="{{scanVisible}}"
    records="{{records}}"
    successMessage="播放页链接写入完成"
    successSubMessage="可以继续写入，或回到我的文件继续管理"
    successPrimaryText="继续写入"
    successSecondaryText="回我的文件"
    bind:close="handleCloseScanDialog"
    bind:secondaryaction="handleGoToFiles"
/>
